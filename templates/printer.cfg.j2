# This file was generated by KACE (Klipper Automated Configuration Ecosystem)
# Board: {{ user.board }}
# Kinematics: {{ user.kinematics }}
# Stepper Drivers: {{ user.driver_type }} ({{ user.driver_mode }})
# Probe: {{ user.probe }}
# Z Motors: {{ user.z_motors }}

# --------------------------------------------------
# Includes
# --------------------------------------------------
{% if user.web_interface == 'Mainsail' -%}
[include mainsail.cfg]
{% elif user.web_interface == 'Fluidd' -%}
[include fluidd.cfg]
{%- endif %}

# --------------------------------------------------
# MCU
# --------------------------------------------------
[mcu]
serial: {{ user.mcu_path | default('/dev/serial/by-id/TODO') }} # Serial connection to the printer controller board. Auto-detected by KACE. Verify in /dev/serial/by-id/ if connection fails.

# --------------------------------------------------
# Printer
# --------------------------------------------------
[printer]
kinematics: {{ user.kinematics }}               # Printer kinematics type (cartesian, corexy, delta)
max_velocity: 300                               # Maximum velocity (in mm/s) of the toolhead
max_accel: 3000                                 # Maximum acceleration (in mm/s^2) of the toolhead
max_z_velocity: 5                               # Maximum velocity (in mm/s) of movement along the z axis
max_z_accel: 100                                # Maximum acceleration (in mm/s^2) of movement along the z axis

# --------------------------------------------------
# Steppers
# --------------------------------------------------
[stepper_x]
{%- if 'stepper_x' in pins %}
step_pin: {{ pins['stepper_x'].get('step_pin', 'TODO') }} # Step pin for the X stepper driver
dir_pin: {{ pins['stepper_x'].get('dir_pin', 'TODO') }} # Direction pin. Add or remove "!" to invert motor direction
enable_pin: {{ pins['stepper_x'].get('enable_pin', 'TODO') }} # Enable pin for the stepper driver
{%- endif %}
microsteps: 16                                  # Number of microsteps per full step
rotation_distance: 40                           # Distance in mm the axis travels per full rotation of the motor
endstop_pin: {{ pins['stepper_x'].get('endstop_pin', 'TODO') if 'stepper_x' in pins else 'TODO' }} # Endstop pin. Add or remove "!" to invert logic
position_endstop: 0                             # Location of the endstop (usually 0)
position_max: {{ user.x_size }}                 # Maximum valid X position
homing_speed: 50                                # Maximum velocity (in mm/s) of the stepper when homing

[stepper_y]
{%- if 'stepper_y' in pins %}
step_pin: {{ pins['stepper_y'].get('step_pin', 'TODO') }} # Step pin for the Y stepper driver
dir_pin: {{ pins['stepper_y'].get('dir_pin', 'TODO') }} # Direction pin. Add or remove "!" to invert motor direction
enable_pin: {{ pins['stepper_y'].get('enable_pin', 'TODO') }} # Enable pin for the stepper driver
{%- endif %}
microsteps: 16                                  # Number of microsteps per full step
rotation_distance: 40                           # Distance in mm the axis travels per full rotation of the motor
endstop_pin: {{ pins['stepper_y'].get('endstop_pin', 'TODO') if 'stepper_y' in pins else 'TODO' }} # Endstop pin. Add or remove "!" to invert logic
position_endstop: 0                             # Location of the endstop (usually 0)
position_max: {{ user.y_size }}                 # Maximum valid Y position
homing_speed: 50                                # Maximum velocity (in mm/s) of the stepper when homing

[stepper_z]
{%- if 'stepper_z' in pins %}
step_pin: {{ pins['stepper_z'].get('step_pin', 'TODO') }} # Step pin for the Z stepper driver
dir_pin: {{ pins['stepper_z'].get('dir_pin', 'TODO') }} # Direction pin. Add or remove "!" to invert motor direction
enable_pin: {{ pins['stepper_z'].get('enable_pin', 'TODO') }} # Enable pin for the stepper driver
{%- endif %}
microsteps: 16                                  # Number of microsteps per full step
rotation_distance: 8                            # Distance in mm the axis travels per full rotation of the motor
{%- if user.probe != 'None' %}
endstop_pin: probe:z_virtual_endstop            # Endstop pin. Add or remove "!" to invert logic
{%- else %}
endstop_pin: {{ pins['stepper_z'].get('endstop_pin', 'TODO') if 'stepper_z' in pins else 'TODO' }} # Endstop pin. Add or remove "!" to invert logic
position_endstop: 0                             # Location of the endstop (usually 0)
{%- endif %}
position_max: {{ user.z_size }}                 # Maximum valid Z position

{%- if user.z_motors == '2' %}

[stepper_z1]
{%- set z1_pins = pins.get('stepper_z1', pins.get('extruder_1', pins.get('extruder1', {}))) %}
{%- if z1_pins %}
step_pin: {{ z1_pins.get('step_pin', 'TODO') }} # Step pin for the Z1 stepper driver
dir_pin: {{ z1_pins.get('dir_pin', 'TODO') }}   # Direction pin. Add or remove "!" to invert motor direction
enable_pin: {{ z1_pins.get('enable_pin', 'TODO') }} # Enable pin for the stepper driver
{%- else %}
step_pin: TODO                                  # Step pin for the Z1 stepper driver
dir_pin: TODO                                   # Direction pin. Add or remove "!" to invert motor direction
enable_pin: TODO                                # Enable pin for the stepper driver
{%- endif %}
microsteps: 16                                  # Number of microsteps per full step
rotation_distance: 8                            # Distance in mm the axis travels per full rotation of the motor
{%- endif %}

[extruder]
{%- if 'extruder' in pins %}
step_pin: {{ pins['extruder'].get('step_pin', 'TODO') }} # Step pin for the extruder driver
dir_pin: {{ pins['extruder'].get('dir_pin', 'TODO') }} # Direction pin. Add or remove "!" to invert motor direction
enable_pin: {{ pins['extruder'].get('enable_pin', 'TODO') }} # Enable pin for the stepper driver
heater_pin: {{ pins['extruder'].get('heater_pin', 'TODO') }} # Pin connected to the hotend heater cartridge
sensor_pin: {{ pins['extruder'].get('sensor_pin', 'TODO') }} # Pin connected to the hotend thermistor
{%- endif %}
microsteps: 16                                  # Number of microsteps per full step
rotation_distance: 33.500                       # Distance in mm the filament travels per full rotation of the motor
nozzle_diameter: 0.400                          # Diameter of the installed nozzle in mm
filament_diameter: 1.750                        # Diameter of the filament being used
sensor_type: EPCOS 100K B57560G104F             # Type of thermistor used for the hotend
control: pid                                    # Temperature control algorithm
pid_Kp: 22.2                                    # PID proportional gain
pid_Ki: 1.08                                    # PID integral gain
pid_Kd: 114                                     # PID derivative gain
min_temp: 0                                     # Minimum safe temperature
max_temp: 250                                   # Maximum safe temperature

# --------------------------------------------------
# Probe
# --------------------------------------------------
{%- if user.probe != 'None' %}
[{{ user.probe | lower }}]
{%- set probe_sec = pins.get('bltouch', pins.get('probe', {})) %}
sensor_pin: {{ probe_sec.get('sensor_pin', '^TODO') }} # Pin connected to the probe sensor
{%- if user.probe | lower == 'bltouch' or 'control_pin' in probe_sec %}
control_pin: {{ probe_sec.get('control_pin', 'TODO') }} # Pin connected to the probe control
{%- endif %}
x_offset: 0                                     # Offset relative to the nozzle. Must be measured for your specific printer
y_offset: 0                                     # Offset relative to the nozzle. Must be measured for your specific printer
z_offset: 0                                     # Z offset should be calibrated using PROBE_CALIBRATE

[safe_z_home]
home_xy_position: {{ user.x_size | int / 2 }}, {{ user.y_size | int / 2 }} # XY position to move to before homing Z
speed: 50                                       # Speed at which the toolhead is moved to the safe Z home coordinate
z_hop: 10                                       # Distance (in mm) to lift the Z axis prior to homing
z_hop_speed: 5                                  # Speed (in mm/s) at which the Z axis is lifted prior to homing
{%- endif %}

# --------------------------------------------------
# Heated Bed
# --------------------------------------------------
[heater_bed]
{%- if 'heater_bed' in pins %}
heater_pin: {{ pins['heater_bed'].get('heater_pin', 'TODO') }} # Pin connected to the heated bed solid state relay or MOSFET
sensor_pin: {{ pins['heater_bed'].get('sensor_pin', 'TODO') }} # Pin connected to the heated bed thermistor
{%- endif %}
sensor_type: EPCOS 100K B57560G104F             # Type of thermistor used for the heated bed
control: pid                                    # Temperature control algorithm
pid_Kp: 54.027                                  # PID proportional gain
pid_Ki: 0.770                                   # PID integral gain
pid_Kd: 948.182                                 # PID derivative gain
min_temp: 0                                     # Minimum safe temperature
max_temp: 130                                   # Maximum safe temperature

